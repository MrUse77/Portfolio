---
interface Props {
  icon: string;
  title: string;
  technologies: string;
}

const { icon, title, technologies } = Astro.props;
---

<div class="p-7 sm:p-8 min-h-[172px] card-gradient border border-border-color rounded-portfolio soft-glow flex flex-col gap-4 hover:border-electric-blue/30 transition-colors">
  <span class="material-symbols-outlined text-electric-blue text-[34px]">{icon}</span>
  <h3 class="font-mono text-sm uppercase tracking-[0.16em] text-off-white font-semibold">{title}</h3>
  <p class="text-sm font-mono text-muted-grey leading-relaxed">{technologies}</p>
</div>
