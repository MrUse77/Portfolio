---
const linkedinUrl = import.meta.env.PUBLIC_LINKEDIN_URL || 'https://shorter.agusdoricich.dev/linkedin';
const githubUrl = import.meta.env.PUBLIC_GITHUB_URL || 'https://shorter.agusdoricich.dev/github';

const socialLinks = [
  { href: linkedinUrl, label: 'LinkedIn', icon: 'link' },
  { href: githubUrl, label: 'GitHub', icon: 'code' },
];

const currentYear = new Date().getFullYear();
---

<footer class="w-full py-12 sm:py-16 bg-navy-dark border-t border-border-color">
  <div class="flex flex-col md:flex-row justify-between items-center px-4 sm:px-6 md:px-8 max-w-7xl mx-auto gap-8 md:gap-12">
    <div class="flex flex-col items-center md:items-start gap-3">
      <div class="text-xl font-bold text-off-white font-mono tracking-tight">
        Agustín Doricich
      </div>
      <p class="font-mono text-xs text-light-grey uppercase tracking-[0.2em] font-medium">
        © {currentYear} Agustín Doricich. Engineered for excellence.
      </p>
    </div>
    <div class="flex gap-12 items-center font-mono text-xs uppercase tracking-[0.3em] font-semibold">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-light-grey hover:text-electric-blue transition-colors flex items-center gap-3"
        >
          <span class="material-symbols-outlined text-base">{link.icon}</span>
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
