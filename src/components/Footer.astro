---
const socialLinks = [
  { href: 'https://linkedin.com/in/agustindoricich', label: 'LinkedIn', icon: 'link' },
  { href: 'https://github.com/agustindoricich', label: 'GitHub', icon: 'terminal' },
];

const currentYear = new Date().getFullYear();
---

<footer class="w-full py-16 bg-navy-dark border-t border-border-color">
  <div class="flex flex-col md:flex-row justify-between items-center px-8 max-w-7xl mx-auto gap-12">
    <div class="flex flex-col items-center md:items-start gap-3">
      <div class="text-xl font-bold text-off-white font-mono tracking-tight">
        Agustín Doricich
      </div>
      <p class="font-mono text-[10px] text-muted-grey uppercase tracking-[0.2em]">
        © {currentYear} Agustín Doricich. Engineered for excellence.
      </p>
    </div>
    <div class="flex gap-12 items-center font-mono text-[10px] uppercase tracking-[0.3em]">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-grey hover:text-electric-blue transition-colors flex items-center gap-3"
        >
          <span class="material-symbols-outlined text-base">{link.icon}</span>
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
