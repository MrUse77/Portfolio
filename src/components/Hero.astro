---
interface Props {
  photoUrl?: string;
}

const { photoUrl } = Astro.props;
---

<section class="min-h-[100dvh] flex items-center pt-24 pb-16 px-4 sm:px-6 md:px-8 relative hero-gradient" id="inicio">
  <div class="max-w-7xl mx-auto w-full grid md:grid-cols-2 gap-10 md:gap-16 items-center">
    <!-- Photo frame -->
    <div class="flex justify-center md:justify-start order-2 md:order-1">
      <div class="relative w-56 h-56 sm:w-64 sm:h-64 md:w-80 md:h-80 lg:w-96 lg:h-96 flex items-center justify-center">
        <div class="absolute inset-0 border border-electric-blue/20 rounded-full animate-pulse"></div>
        <div class="absolute inset-3 sm:inset-4 border border-electric-blue/40 rounded-full"></div>
        <div class="w-[85%] h-[85%] rounded-full overflow-hidden flex items-center justify-center bg-navy-surface text-muted-grey border-2 border-electric-blue/10">
          {photoUrl ? (
            <img src={photoUrl} alt="Agustín Doricich" class="w-full h-full object-cover" />
          ) : (
            <span class="material-symbols-outlined text-9xl opacity-20">person</span>
          )}
        </div>
      </div>
    </div>

    <!-- Text content -->
    <div class="space-y-8 order-1 md:order-2">
      <div class="space-y-3">
        <span class="font-mono text-electric-blue tracking-[0.25em] text-sm uppercase block font-medium">
          Hola, mi nombre es
        </span>
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-off-white">
          Agustín Doricich.
        </h1>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-muted-grey">
          Estudiante de Ingeniería Informática.
        </h2>
        <p class="text-xl text-electric-blue font-mono mt-4">Construyo cosas para la web.</p>
      </div>
      <p class="text-lg text-muted-grey font-medium max-w-xl leading-relaxed border-l-2 border-electric-blue/30 pl-6">
        Soy un desarrollador de software enfocado en crear experiencias digitales excepcionales. Actualmente, me especializo en construir productos accesibles y centrados en el usuario con las últimas tecnologías.
      </p>
      <div class="pt-4 flex flex-wrap gap-4 font-mono text-xs uppercase tracking-widest">
        <a
          href="#proyectos"
          class="px-8 py-4 bg-electric-blue text-navy-dark font-bold rounded-portfolio hover:scale-[1.02] active:scale-[0.98] transition-all shadow-[0_10px_20px_-10px_rgba(0,224,255,0.4)]"
        >
          Ver mis proyectos
        </a>
        <a
          href="#contacto"
          class="px-8 py-4 border border-border-color text-off-white font-bold rounded-portfolio hover:bg-navy-surface transition-all"
        >
          Ponerme en contacto
        </a>
      </div>
    </div>
  </div>
</section>
