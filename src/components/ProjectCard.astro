---
interface Props {
  title: string;
  description: string;
  techStack: string[];
  image?: string;
  githubLink?: string;
  liveLink?: string;
  icon?: string;
}

const { title, description, techStack, image, githubLink, liveLink, icon = 'folder' } = Astro.props;
---

<div class="bg-navy-surface/40 border border-border-color p-0 rounded-portfolio overflow-hidden hover:-translate-y-2 transition-all duration-300 group shadow-lg flex flex-col">
  <!-- Image -->
  <div class="h-40 sm:h-48 overflow-hidden relative">
    <div class="absolute inset-0 bg-navy-dark/40 group-hover:bg-transparent transition-colors z-10"></div>
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      />
    ) : (
      <div class="w-full h-full bg-navy-surface flex items-center justify-center">
        <span class="material-symbols-outlined text-6xl text-muted-grey/20">image</span>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-5 sm:p-8 flex flex-col flex-grow">
    <div class="flex justify-between items-start mb-6">
      <span class="material-symbols-outlined text-electric-blue text-3xl">{icon}</span>
      <div class="flex items-center gap-3 text-muted-grey">
        {githubLink && (
          <a
            href={githubLink}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-grey hover:text-electric-blue transition-colors"
            aria-label="GitHub"
          >
            <span class="material-symbols-outlined text-xl">code</span>
          </a>
        )}
        {liveLink && (
          <a
            href={liveLink}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-grey hover:text-electric-blue transition-colors"
            aria-label="Demo en vivo"
          >
            <span class="material-symbols-outlined text-xl">open_in_new</span>
          </a>
        )}
      </div>
    </div>
    <h3 class="text-xl font-bold text-off-white mb-4">{title}</h3>
    <p class="text-muted-grey text-sm mb-6 flex-grow leading-relaxed font-normal">{description}</p>
    <div class="font-mono text-[11px] text-electric-blue/90 uppercase tracking-[0.18em] flex flex-wrap gap-2 leading-relaxed">
      {techStack.map((tech) => (
        <span class="px-2 py-1 bg-navy-dark/80 rounded-full border border-border-color/80">
          {tech}
        </span>
      ))}
    </div>
  </div>
</div>
