---
import { getCollection } from 'astro:content';

const experiences = await getCollection('experience');
// Sort by dateStart descending (most recent first)
const sorted = experiences.sort((a, b) => b.data.dateStart.valueOf() - a.data.dateStart.valueOf());

function formatDate(date: Date): string {
  const months = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
  return `${months[date.getMonth()]} ${date.getFullYear()}`;
}
---

<section class="py-16 sm:py-24 md:py-32 px-4 sm:px-6 md:px-8 scroll-mt-24 sm:scroll-mt-28" id="experiencia">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="flex items-center gap-6 mb-16">
      <h2 class="text-sm font-mono text-electric-blue flex items-center">
        <span class="text-lg mr-2">03.</span>
        <span class="text-off-white uppercase tracking-[0.2em] font-semibold">Experiencia</span>
      </h2>
      <div class="h-[1px] bg-gradient-to-r from-electric-blue/30 to-transparent flex-grow"></div>
    </div>

    <!-- Experience cards -->
    <div class="space-y-6">
      {sorted.map((exp) => (
        <div class="card-gradient border border-border-color rounded-portfolio p-6 sm:p-8 hover:border-electric-blue/30 transition-all duration-300 group">
          <!-- Top row: role + type badge -->
          <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
            <h3 class="text-xl sm:text-2xl font-semibold text-off-white group-hover:text-electric-blue transition-colors">
              {exp.data.role}
            </h3>
            <span class="px-3 py-1 text-xs font-mono uppercase tracking-wider border border-electric-blue/40 text-electric-blue rounded-full whitespace-nowrap">
              {exp.data.type}
            </span>
          </div>

          <!-- Company name -->
          <p class="font-mono text-sm text-electric-blue mb-2">
            {exp.data.company}
          </p>

          <!-- Date range -->
          <p class="font-mono text-xs text-muted-grey mb-4">
            {formatDate(exp.data.dateStart)} — {exp.data.dateEnd ? formatDate(exp.data.dateEnd) : 'Presente'}
          </p>

          <!-- Description -->
          <p class="text-muted-grey leading-relaxed">
            {exp.data.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
